version: "2"
sql:
  - engine: "postgresql"
    queries: "./sql"
    schema: "./migrations"
    gen:
      go:
        package: "generated"
        out: "database/generated"
        sql_package: "pgx/v5"
        emit_json_tags: true
        emit_interface: true
        emit_db_tags: true
        rename:
          medium: "Media"
        overrides:
          - db_type: "timestamptz"
            go_type:
              type: "time.Time"
          - db_type: "timestamptz"
            nullable: true
            go_type:
              type: "*time.Time"
